---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('posts');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Notícies">
  <div class="page-wrap">
    <h1 class="page-title">Notícies</h1>

    {posts.length === 0 ? (
      <p style="color: var(--dim); font-size: 13px; letter-spacing: 3px; text-transform: uppercase;">No hi ha notícies encara.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/posts/${post.id}`}>
              <span class="post-title">{post.data.title}</span>
              <span class="post-date">
                {post.data.date.toLocaleDateString('ca-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
