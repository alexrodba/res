<!-- ─── LYRICS ─── -->
<section id="lyrics">
  <div class="section-full" style="max-width:1280px; margin:0 auto;">
    <p class="eyebrow">Lletres</p>

    {albums.map((album, ai) => {
      const songs = byAlbum.get(album.name) ?? [];
      return (
        <>
          <div class="lyrics-album-header" style={ai > 0 ? 'margin-top:60px;' : ''}>
            <span class="lyrics-album-title">{album.name}</span>
            <span class="lyrics-album-year">{album.year}</span>
          </div>
          <div class="lyrics-grid">
            {songs.map((lyric, j) => (
              <div class="lyric-row" data-lyric-toggle>
                <div class="lyric-header">
                  <span class="lyric-num">{String(j + 1).padStart(2, '0')}</span>
                  <span class="lyric-title">{lyric.data.title}</span>
